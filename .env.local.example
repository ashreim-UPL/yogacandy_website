# ─────────────────────────────────────────────────────────────────────────────
# YogaCandy — Environment Variables
# Copy this file to .env.local (never commit .env.local — it is gitignored)
# ─────────────────────────────────────────────────────────────────────────────

# ── Google Maps ───────────────────────────────────────────────────────────────
# Used for: location reverse-geocoding, Maps Embed nearby studios
#
# Setup:
#   1. Go to console.cloud.google.com → APIs & Services → Credentials
#   2. Create an API Key
#   3. Enable: Maps JavaScript API, Maps Embed API, Geocoding API
#   4. Under "Application restrictions" → HTTP referrers:
#        yogacandy.info/*
#        www.yogacandy.info/*
#        localhost:3000/*   (dev only — remove in production key)
#   5. Under "API restrictions" → Restrict to the three APIs above
#
# The key is NEXT_PUBLIC_ because it is used client-side (Maps Embed API).
# It is safe because Google restricts it to your domain.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ── Supabase ──────────────────────────────────────────────────────────────────
# Used for: authentication (email + SSO), user profiles, GDPR data storage
#
# Setup:
#   1. Create a free project at supabase.com (choose EU region for GDPR)
#   2. Go to Settings → API
#   3. Copy "Project URL" and "anon public" key below
#   4. In Authentication → Providers, enable: Google, Apple, Facebook
#      (each requires OAuth credentials from the respective developer console)
#   5. In Authentication → URL Configuration:
#        Site URL:           https://yogacandy.info
#        Redirect URLs:      https://yogacandy.info/auth/callback
#
# The anon key is NEXT_PUBLIC_ and safe to expose — it is restricted by
# Row Level Security (RLS) policies in your Supabase project.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ── Google AdSense ────────────────────────────────────────────────────────────
# Used for: display ad monetization (auto-ads)
#
# Setup:
#   1. Apply at google.com/adsense (takes 1–2 weeks for approval)
#   2. Once approved, go to AdSense → Account → Account information
#   3. Copy your Publisher ID (format: ca-pub-XXXXXXXXXXXXXXXX)
#   4. Paste it below — auto-ads will activate immediately on next deploy
#
# Leave blank to disable ads (e.g. during development)
NEXT_PUBLIC_ADSENSE_ID=ca-pub-XXXXXXXXXXXXXXXX

# ── Google Search Console ─────────────────────────────────────────────────────
# Used for: verifying site ownership so you can submit sitemaps and monitor rankings
#
# Setup:
#   1. Go to search.google.com/search-console → Add property → URL prefix
#   2. Enter: https://yogacandy.info
#   3. Choose "HTML tag" verification method
#   4. Copy the content value from the meta tag (e.g. "abc123xyz...")
#   5. Paste it below and deploy — Google will verify automatically
#   6. After verification, submit: https://yogacandy.info/sitemap.xml
#
NEXT_PUBLIC_GSC_VERIFICATION=your_google_site_verification_code_here
